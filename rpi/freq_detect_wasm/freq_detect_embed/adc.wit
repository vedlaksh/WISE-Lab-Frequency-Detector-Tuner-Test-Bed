package local:demo;


world host {
    import rpi: interface {
        host-alsa-capture-init: func() -> s32;
        // returns one analysis block of raw 48 kHz mono samples in a single call
        host-read-block: func(len: u32) -> list<s16>;
        host-snd-pcm-close: func();
        host-printf: func(msg: string);
        host-sin: func(x: f64) -> f64;
        host-cos: func(x: f64) -> f64;
        // returns 1 to keep recording/running, 0 to stop (set by Ctrl-C on the host).
        // Its return value is recorded, so replay stops at the identical iteration.
        host-should-continue: func() -> s32;
    }

    export run: func() -> s32;
}